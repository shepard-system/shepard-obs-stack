    {
      "id": 10,
      "title": "Tool Calls Over Time",
      "description": "Tool call activity by provider",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "round(sum(increase(shepherd_tool_calls_total{source=\"claude\",git_repo=~\"$git_repo\"}[$__rate_interval])))",
          "legendFormat": "Claude",
          "queryType": "range",
          "refId": "A",
          "interval": "1m"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "round(sum(increase(shepherd_tool_calls_total{source=\"gemini\",git_repo=~\"$git_repo\"}[$__rate_interval])))",
          "legendFormat": "Gemini",
          "queryType": "range",
          "refId": "B",
