    {
      "id": 6,
      "title": "Cache Efficiency",
      "description": "Cache read ratio: cache_read / (input + cache_read). Higher = more tokens served from cache.",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum(max_over_time(shepherd_claude_code_token_usage_tokens_total{type=\"cacheRead\"}[$__range])) / clamp_min(sum(max_over_time(shepherd_claude_code_token_usage_tokens_total{type=\"input\"}[$__range])) + sum(max_over_time(shepherd_claude_code_token_usage_tokens_total{type=\"cacheRead\"}[$__range])), 1)",
          "legendFormat": "Claude",
          "queryType": "instant",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum(max_over_time(shepherd_gemini_cli_token_usage_total{type=\"cache\"}[$__range])) / clamp_min(sum(max_over_time(shepherd_gemini_cli_token_usage_total{type=\"input\"}[$__range])) + sum(max_over_time(shepherd_gemini_cli_token_usage_total{type=\"cache\"}[$__range])), 1)",
          "legendFormat": "Gemini",
          "queryType": "instant",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum(sum_over_time(shepherd:codex:tokens_cached:1m[$__range])) / clamp_min(sum(sum_over_time(shepherd:codex:tokens_input:1m[$__range])) + sum(sum_over_time(shepherd:codex:tokens_cached:1m[$__range])), 1)",
          "legendFormat": "Codex",
          "queryType": "instant",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed" },
          "unit": "percentunit",
          "decimals": 1,
          "min": 0,
          "max": 1,
          "noValue": "–"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Claude" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#8B5CF6" } }] },
          { "matcher": { "id": "byName", "options": "Gemini" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#10B981" } }] },
          { "matcher": { "id": "byName", "options": "Codex" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#F59E0B" } }] }
        ]
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "minVizWidth": 8,
        "minVizHeight": 16
      }
    },

