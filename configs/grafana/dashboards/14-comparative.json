          "legendFormat": "Gemini",
          "queryType": "instant",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "round(sum(sum_over_time({__name__=~\"shepherd:codex:tokens_.+:1m\"}[$__range]))) > 0",
          "legendFormat": "Codex",
          "queryType": "instant",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed" },
          "decimals": 0,
          "noValue": "–"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Claude" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#8B5CF6" } }] },
          { "matcher": { "id": "byName", "options": "Gemini" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#10B981" } }] },
          { "matcher": { "id": "byName", "options": "Codex" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#F59E0B" } }] }
        ]
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "legend": { "displayMode": "list", "placement": "bottom", "values": ["value", "percent"] },
        "pieType": "donut",
        "tooltip": { "mode": "single" }
      }
    },

    {
      "id": 200,
      "title": "Token Breakdown",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "panels": []
