{
  "uid": "shepherd-comparative",
  "id": null,
  "title": "Shepherd / 09 Comparative",
  "description": "Side-by-side comparison of Claude Code, Gemini CLI, and Codex: sessions, cost, tokens, tools, and quality.\n\nRequires: at least one provider session with hooks installed.\nCost metrics: Claude Code only.",
  "editable": true,
  "refresh": "1m",
  "weekStart": "monday",
  "timezone": "browser",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "tags": [
    "shepherd",
    "comparative"
  ],
  "version": 1,
  "schemaVersion": 39,
  "graphTooltip": 1,
  "links": [],
  "timepicker": {},
  "annotations": {
    "list": []
  },
  "templating": {
    "list": [
      {
        "current": {
          "selected": false,
          "text": ".*",
          "value": ".*"
        },
        "name": "git_repo",
        "label": "Git Repo",
        "type": "textbox",
        "query": ".*",
        "description": "Filter by git repo name (regex). Applies to hook metrics only. Use .* for all."
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "title": "Overview",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "id": 1,
      "title": "Sessions by Provider",
      "description": "Count of distinct sessions per provider",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "count(max_over_time(shepherd_claude_code_session_count_total[$__range]))",
          "legendFormat": "Claude",
          "queryType": "instant",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "count(max_over_time(shepherd_gemini_cli_session_count_total[$__range]))",
          "legendFormat": "Gemini",
          "queryType": "instant",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "round(sum(sum_over_time(shepherd:codex:sessions:1m[$__range]))) > 0",
          "legendFormat": "Codex",
          "queryType": "instant",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed" },
          "decimals": 0,
          "noValue": "–"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Claude" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#8B5CF6" } }] },
          { "matcher": { "id": "byName", "options": "Gemini" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#10B981" } }] },
          { "matcher": { "id": "byName", "options": "Codex" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#F59E0B" } }] }
        ]
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "legend": { "displayMode": "list", "placement": "bottom", "values": ["value", "percent"] },
        "pieType": "donut",
        "tooltip": { "mode": "single" }
      }
    },
    {
      "id": 2,
      "title": "Cost by Provider",
      "description": "Claude Code only — other providers don't emit cost metrics",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum(max_over_time(shepherd_claude_code_cost_usage_USD_total[$__range])) > 0",
          "legendFormat": "Claude",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed" },
          "unit": "currencyUSD",
          "decimals": 2,
          "noValue": "–"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Claude" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#8B5CF6" } }] },
          { "matcher": { "id": "byName", "options": "Gemini" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#10B981" } }] },
          { "matcher": { "id": "byName", "options": "Codex" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#F59E0B" } }] }
        ]
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "legend": { "displayMode": "list", "placement": "bottom", "values": ["value", "percent"] },
        "pieType": "donut",
        "tooltip": { "mode": "single" }
      }
    },
    {
      "id": 3,
      "title": "Tokens by Provider",
      "description": "Total tokens (all types) per provider",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "round(sum(max_over_time(shepherd_claude_code_token_usage_tokens_total[$__range]))) > 0",
          "legendFormat": "Claude",
          "queryType": "instant",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
